VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: used only to show the Admin link in the UI (admin auth is enforced server-side in Edge Functions).
VITE_ADMIN_EMAIL=

# Optional: enable hCaptcha for poll suggestions (recommended).
VITE_HCAPTCHA_SITE_KEY=

# Optional: if you want to read polls from a separate "poll bank" Supabase project.
VITE_POLL_BANK_SUPABASE_URL=
VITE_POLL_BANK_SUPABASE_ANON_KEY=
